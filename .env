# =========================
# 基础配置
# =========================

# 服务端口
PORT=8080

# 数据/文件路径
FILE_PATH=./world

# UUID（建议自行生成）
UUID=fe7431cb-ab1b-4205-a14c-d056f821b383

# 节点名称（随便填，用于标识）
NAME=MyNode


# =========================
# Nezha 探针（可选）
# =========================

NEZHA_SERVER=example.com
NEZHA_PORT=5555
NEZHA_KEY=your_nezha_key


# =========================
# Argo 隧道（Cloudflare）（可选）
# =========================

ARGO_PORT=8080
ARGO_DOMAIN=your.domain.com
ARGO_AUTH=your_argo_auth_json_or_token

# 是否禁用 Argo（true=禁用，false=启用）
DISABLE_ARGO=false


# =========================
# 各协议端口（按需开启）
# =========================

S5_PORT=1080
HY2_PORT=8443
TUIC_PORT=4433
ANYTLS_PORT=4443
REALITY_PORT=4453
ANYREALITY_PORT=4463


# =========================
# Cloudflare 回源（可选）
# =========================

CFIP=cdns.doon.eu.org
CFPORT=443


# =========================
# Telegram 通知（可选）
# =========================

UPLOAD_URL=https://example.com/upload
CHAT_ID=123456789
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11


# =========================
# Komari 探针（可选）
# =========================

KOMARI_SERVER=https://komari.example.com
KOMARI_KEY=your_komari_key

CERT_URL=https://example.com/cert.pem
KEY_URL=https://example.com/private.key
